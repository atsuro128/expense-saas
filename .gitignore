# プロダクトリポジトリのGit追跡除外ルール

# 環境変数
.env
.env.*
!.env.example

# Go
bin/
/server
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Node.js / Frontend
node_modules/
dist/
# cmd/server/frontend/dist/ は go:embed のスタブ（.gitkeep）のみ追跡する。
# 実際の Vite build 成果物は Dockerfile の frontend-builder stage で生成される。
# git では「ディレクトリが ignore されるとファイルのネゲーションが効かない」仕様があるため、
# ディレクトリ自体と .gitkeep を個別にネゲーションする。
!cmd/server/frontend/
!cmd/server/frontend/dist/
!cmd/server/frontend/dist/.gitkeep
.next/
coverage/
*.tsbuildinfo

# Playwright E2E
playwright-report/
test-results/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo

# JWT keys
keys/

# Docker
docker-compose.override.yml

# Logs
*.log

# Claude Code
.claude/

# Temp
tmp/
