# Database (owner role - RLS bypass, used for migrations and auth endpoints)
POSTGRES_USER=expense_owner
POSTGRES_PASSWORD=localdev
POSTGRES_DB=expense_saas
POSTGRES_PORT=5432
DATABASE_URL=postgres://expense_owner:localdev@db:5432/expense_saas?sslmode=disable

# Application DB (app role - RLS applied, used for business logic)
APP_DATABASE_URL=postgres://expense_app:localdev@db:5432/expense_saas?sslmode=disable

# JWT
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# Server
PORT=8080
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=debug

# Frontend
FRONTEND_PORT=5173

# S3 / MinIO（env_config.md §4.4 参照）
# ローカル開発では MinIO を使用する（ADR-0004 ローカル構成方針）。
# stg / prod では環境変数を未設定にし、ECS タスクロール（IAM ロール）で S3 に接続する。
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=expense-saas-receipts-dev
AWS_REGION=ap-northeast-1

# MinIO 管理者認証情報（docker-compose の minio サービス用）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
