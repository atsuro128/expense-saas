#!/usr/bin/env bash
set -euo pipefail

# ステージングされた .go ファイルを取得
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -n "$GO_FILES" ]; then
  # gofmt で未フォーマットのファイルを検出
  UNFORMATTED=$(echo "$GO_FILES" | xargs gofmt -l 2>/dev/null || true)
  if [ -n "$UNFORMATTED" ]; then
    echo "[pre-commit] gofmt: 以下のファイルをフォーマットします:"
    echo "$UNFORMATTED"
    echo "$UNFORMATTED" | xargs gofmt -w
    echo "$UNFORMATTED" | xargs git add
  fi
fi

# ステージングされた .ts/.tsx ファイルを取得
TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$TS_FILES" ]; then
  # prettier でチェック
  if ! echo "$TS_FILES" | xargs npx prettier --check --loglevel warn 2>/dev/null; then
    echo "[pre-commit] prettier: 以下のファイルをフォーマットします:"
    echo "$TS_FILES"
    echo "$TS_FILES" | xargs npx prettier --write --loglevel warn
    echo "$TS_FILES" | xargs git add
  fi
fi
